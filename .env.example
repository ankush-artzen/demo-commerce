COMPANY_NAME="Vercel Inc."
SITE_NAME="Next.js Commerce"
SHOPIFY_REVALIDATION_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"
# Advice feed: auto | blog | products (auto = blog if handles set, else products)
SHOPIFY_ADVICE_FEED_SOURCE="auto"
# Shopify blog handles (Online Store > Blog posts) — Palace-style editorial feed
SHOPIFY_ADVICE_BLOG_HANDLE="advice"
SHOPIFY_LOOKBOOK_BLOG_HANDLE="lookbook"
# Fallback when no blogs: collection handle for product grid (default: all)
SHOPIFY_ADVICE_COLLECTION_HANDLE="all"
